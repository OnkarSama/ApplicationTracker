<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f4f4f5; margin: 0; padding: 32px 16px; }
      .card { background: #fff; border-radius: 12px; max-width: 480px; margin: 0 auto; padding: 40px 36px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
      .logo { font-size: 20px; font-weight: 800; color: #6366f1; margin-bottom: 28px; }
      h1 { font-size: 22px; font-weight: 700; color: #111827; margin: 0 0 10px; }
      p { color: #6b7280; font-size: 15px; line-height: 1.6; margin: 0 0 20px; }
      .btn { display: inline-block; background: linear-gradient(135deg, #6366f1, #7c3aed); color: #fff !important; text-decoration: none; padding: 13px 28px; border-radius: 8px; font-weight: 600; font-size: 15px; }
      .expiry { font-size: 13px; color: #9ca3af; margin-top: 24px; }
      hr { border: none; border-top: 1px solid #f3f4f6; margin: 28px 0; }
      .fallback { font-size: 12px; color: #9ca3af; word-break: break-all; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="logo">AppTracker</div>

      <h1>Reset your password</h1>
      <p>We received a request to reset the password for <strong><%= @user.email_address %></strong>. Click the button below to choose a new one.</p>

      <% token = @user.generate_token_for(:password_reset) %>
      <% reset_url = "#{ENV.fetch('FRONTEND_URL', 'http://localhost:3000')}/reset-password?token=#{token}" %>

      <a href="<%= reset_url %>" class="btn">Reset Password</a>

      <p class="expiry">This link expires in <strong>15 minutes</strong>. If you didn't request this, you can safely ignore this email.</p>

      <hr>
      <p class="fallback">Button not working? Copy this URL:<br><%= reset_url %></p>
    </div>
  </body>
</html>
